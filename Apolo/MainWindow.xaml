<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Apolo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:Apolo"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:Microsoft.UI.Xaml.Controls"
        Title="Apolo"
        Activated="Window_Activated"
        mc:Ignorable="d">

    <ui:NavigationView x:Name="NavView"
                       IsSettingsVisible="True"
                       PaneDisplayMode="Left"
                       SelectionChanged="NavView_SelectionChanged">

        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Lessons"
                                   Icon="Calendar"
                                   Tag="lessons" />
            <ui:NavigationViewItem Content="Invoicing"
                                   Icon="Calculator"
                                   Tag="invoicing" />
            <ui:NavigationViewItem Content="Payers"
                                   Icon="People"
                                   Tag="payers" />
            <ui:NavigationViewItem Content="Students"
                                   Icon="Contact"
                                   Tag="students" />
            <ui:NavigationViewItem Content="Services"
                                   Icon="Edit"
                                   Tag="services" />
            <ui:NavigationViewItem Content="Specifications"
                                   Icon="SolidStar"
                                   Tag="specifications" />
            <ui:NavigationViewItem Content="Settings"
                                   Icon="Setting"
                                   Tag="settings" />
        </ui:NavigationView.MenuItems>
        
        <Frame x:Name="RootFrame" />
    </ui:NavigationView>
</Window>
