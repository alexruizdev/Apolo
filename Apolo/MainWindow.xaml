<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="Apolo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="using:Apolo"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:Microsoft.UI.Xaml.Controls"
        xmlns:loc="using:Apolo.Service"
        Title="Apolo"
        Activated="Window_Activated"
        mc:Ignorable="d">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  TitleBar  -->
            <RowDefinition Height="*" />
            <!--  NavigationView  -->
        </Grid.RowDefinitions>
        
        <TitleBar Title="Apolo"
                  Subtitle="Invoice manager"
                  IsBackButtonVisible="False"
                  IsPaneToggleButtonVisible="False">

            <TitleBar.Content>
                <AutoSuggestBox Width="360"
                                VerticalAlignment="Center"
                                PlaceholderText="Search.."
                                QueryIcon="Find" />
            </TitleBar.Content>

        </TitleBar>



        <ui:NavigationView x:Name="NavView"
                           Grid.Row="1"
                           IsSettingsVisible="False"
                           PaneDisplayMode="Left"
                           SelectionChanged="NavView_SelectionChanged">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Lessons}"
                                       Icon="Calendar"
                                       Tag="lessons" />
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Invoicing}"
                                       Icon="Calculator"
                                       Tag="invoicing" />
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Payers}"
                                       Icon="People"
                                       Tag="payers" />
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Students}"
                                       Icon="Contact"
                                       Tag="students" />
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Services}"
                                       Icon="Edit"
                                       Tag="services" />
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Specifications}"
                                       Icon="SolidStar"
                                       Tag="specifications" />
                <ui:NavigationViewItem Content="{x:Bind loc:Loc.Menu_Settings}"
                                       Icon="Setting"
                                       Tag="settings" />
            </ui:NavigationView.MenuItems>

            <Frame x:Name="RootFrame" />
        </ui:NavigationView>

    </Grid>
</Window>
