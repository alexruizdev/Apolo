<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="Apolo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:Apolo.Converters"
             xmlns:local="using:Apolo">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Invert="True" />
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:DecimalToCurrencyConverter x:Key="DecimalToCurrencyConverter" />
            <conv:DateFormatConverter x:Key="DateFormatConverter" />
            <conv:InfoBarTypeConverter x:Key="InfoBarTypeConverter" />
            <conv:NumberSignToColorConverter x:Key="NumberSignToColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
