<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================= -->
    <!-- MAIN VIEW                                                         -->
    <!-- ================================================================= -->
    
    <!-- Grid -->
    <Style x:Key="MainGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="24"/>
        <Setter Property="RowSpacing" Value="16"/>
    </Style>

    <!-- ================================================================= -->
    <!-- SEMANTIC STATUS BADGES (ADAPTIVE TO LIGHT/DARK THEMES)            -->
    <!-- ================================================================= -->

    <!-- PAID Badge Style -->
    <Style x:Key="PaidBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SystemFillColorSuccessBackgroundBrush}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="PaidTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource SystemFillColorSuccess }"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- UNPAID Badge Style -->
    <Style x:Key="UnpaidBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SystemFillColorCriticalBackgroundBrush}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="UnpaidTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCritical}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- ONLINE Badge Style -->
    <Style x:Key="OnlineBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="OnlineTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource SystemAccentColor}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- WEEKEND Badge Style -->
    <Style x:Key="WeekendBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource SystemFillColorCautionBackgroundBrush}" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style x:Key="WeekendTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCautionBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- SETTINGS Badge Style -->
    <Style x:Key="SettingUtilitiesStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
        <Setter Property="Margin" Value="0" />
    </Style>


    <!-- ================================================================= -->
    <!-- LIST VIEW ITEM CARD LAYOUTS                                       -->
    <!-- ================================================================= -->

    <!-- Standardized Container for Lesson Rows -->
    <Style x:Key="CardGridStyle" TargetType="Grid">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,4,0,4" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ColumnSpacing" Value="16" />
    </Style>

    <Style x:Key="CardPanelStyle" TargetType="StackPanel">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Spacing" Value="12" />
    </Style>

    <Style x:Key="OverlayPaneBorderStyle" TargetType="Border">
        <Setter Target="Background" Value="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
        <Setter Target="BorderBrush" Value="{ThemeResource SystemControlForegroundBaseLowBrush}" />
        <Setter Target="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
    </Style>

    <!-- ================================================================= -->
    <!-- ROW INTERACTION BUTTONS                                           -->
    <!-- ================================================================= -->

    <!-- Base Transparent Action Button Style -->
    <Style x:Key="RowActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
    </Style>
    
    <!-- Destructive/Delete Action Button Style -->
    <Style x:Key="RowDeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}" >
        <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
    </Style>

    <Style x:Key="RowDeleteMenuFlyoutItemStyle" TargetType="MenuFlyoutItem">
        <Setter Property="Foreground" Value="{ThemeResource SystemFillColorCriticalBrush}" />
    </Style>
    <!-- ================================================================= -->
    <!-- ROW INTERACTION BUTTONS                                           -->
    <!-- ================================================================= -->

    <!-- Scroll Viewer -->
    <Style x:Key="MainScrollStyle" TargetType="ScrollViewer">
        <Setter Property="Padding" Value="24" />
        <Setter Property="MaxHeight" Value="600" />
        <Setter Property="VerticalScrollMode" Value="Enabled" />
        <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
    </Style>

    <Style x:Key="PriceNumberBox" TargetType="NumberBox">
        <Setter Property="SpinButtonPlacementMode" Value="Inline"/>
        <Setter Property="SmallChange" Value="2.5" />
        <Setter Property="LargeChange" Value="5" />
        <Setter Property="MaxWidth" Value="250" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Minimum" Value="0" />
    </Style>
    <Style x:Key="TimeNumberBox" TargetType="NumberBox">
        <Setter Property="SpinButtonPlacementMode" Value="Inline"/>
        <Setter Property="SmallChange" Value="15" />
        <Setter Property="LargeChange" Value="30" />
        <Setter Property="Minimum" Value="15" />
    </Style>

    <!-- ================================================================= -->
    <!-- DASHBOARD                                                         -->
    <!-- ================================================================= -->

    <Style x:Key="MetricBorder" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BorderBrush" Value="{ThemeResource SurfaceStrokeColorDefaultBrush}" /> <!--CardStrokeColorDefaultBrush-->
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    
    <Style x:Key="ReportTitle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
        <Setter Property="CharacterSpacing" Value="60"/>
    </Style>
</ResourceDictionary>
