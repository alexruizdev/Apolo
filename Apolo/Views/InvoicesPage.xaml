<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <Grid Style="{StaticResource MainGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Uid="Title/Invoicing"
                       Style="{ThemeResource TitleLargeTextBlockStyle}" 
                       VerticalAlignment="Top"/>

            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        Spacing="12" 
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.EditMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">

                <TextBlock Text="•" 
                           Style="{ThemeResource TitleLargeTextBlockStyle}" 
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" 
                           VerticalAlignment="Center"/>

                <TextBlock Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center">
                    <Run x:Uid="Common/ActiveBill" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Run Text="{x:Bind ViewModel.Bill.Name, Mode=OneWay}" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"/>
                </TextBlock>

                <TextBlock Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center">
                    <Run x:Uid="Common/Date" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    <Run Text="{x:Bind ViewModel.Bill.Date, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="320, *" ColumnSpacing="24">

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" Padding="0,0,4,0">

                    <StackPanel Style="{StaticResource CardPanelStyle}">
                        <TextBlock x:Uid="Common/NewInvoice" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <ComboBox x:Uid="Common/Payer"
                                  ItemsSource="{Binding Payers}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="FullName"
                                  SelectedValue="{x:Bind ViewModel.SelectedPayerId, Mode=TwoWay}" 
                                  HorizontalAlignment="Stretch"/>
                        <Button x:Uid="Buttons/LoadLessons" Click="LoadForPayer_Click" Style="{ThemeResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Style="{StaticResource CardPanelStyle}">
                        <TextBlock x:Uid="Common/EditBill" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <AutoSuggestBox x:Uid="Common/SearchBill"
                                        PlaceholderText="e.g. 2024-03..."
                                        Text="{x:Bind ViewModel.SearchBillText, Mode=TwoWay}"
                                        ItemsSource="{x:Bind ViewModel.BillSuggestions, Mode=OneWay}"
                                        DisplayMemberPath="DocumentNumber"
                                        TextMemberPath="DocumentNumber"
                                        UpdateTextOnSelect="True"
                                        TextChanged="BillSearch_TextChanged"
                                        SuggestionChosen="BillSearch_SuggestionChosen"
                                        HorizontalAlignment="Stretch"/>
                        <Button x:Uid="Buttons/LoadBill" Click="LoadForBill_Click" Style="{ThemeResource AccentButtonStyle}"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Style="{StaticResource CardPanelStyle}" Spacing="8">
                        <TextBlock x:Uid="Common/Summary" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <CheckBox x:Uid="Buttons/SelectAll" IsThreeState="True" IsChecked="{x:Bind ViewModel.SelectionState, Mode=TwoWay}" Margin="0" />
                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}">
                            <Run x:Uid="Common/Selected" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            <Run Text="{x:Bind ViewModel.TotalSelected, Mode=OneWay, Converter={StaticResource DecimalToCurrencyConverter}}" FontWeight="Bold" />
                        </TextBlock>
                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}">
                             <Run x:Uid="Common/TotalAll" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                             <Run Text="{x:Bind ViewModel.TotalAll, Mode=OneWay, Converter={StaticResource DecimalToCurrencyConverter}}" FontWeight="Bold" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Background="Transparent" HorizontalAlignment="Left">
                    <AppBarButton x:Uid="Buttons/MarkPaid" Icon="Accept" Click="MarkPaid_Click" IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                    <AppBarButton x:Uid="Buttons/MarkUnpaid" Icon="Undo" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Click="MarkUnpaid_Click" IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                    <AppBarButton x:Uid="Buttons/Remove" Icon="Remove" Click="RemoveLesson_Click" Visibility="{x:Bind ViewModel.EditMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <AppBarSeparator />
                    <AppBarButton x:Uid="Buttons/NewInvoice" Icon="Document" Click="CreateInvoice_Click" Visibility="{x:Bind ViewModel.EditMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <AppBarButton x:Uid="Buttons/NewTicket" Icon="Tag" Click="CreateTicket_Click" Visibility="{x:Bind ViewModel.EditMode, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <AppBarSeparator />
                    <AppBarButton x:Uid="Buttons/ExportPdf" Icon="Print" Command="{x:Bind ViewModel.PrintDocumentCommand}" Visibility="{x:Bind ViewModel.EditMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <AppBarButton x:Uid="Delete" Icon="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Click="DeleteBill_Click" Visibility="{x:Bind ViewModel.EditMode, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </CommandBar>

                <StackPanel Grid.Row="1" Spacing="4">
                    <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                    <InfoBar IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}" Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}" Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
                </StackPanel>

                <ListView Grid.Row="2" ItemsSource="{Binding Lessons}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:InvoiceLine">
                            <Grid Style="{StaticResource CardGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Data.Date, Converter={StaticResource DateFormatConverter}}" Style="{ThemeResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                                    <Run Text="{x:Bind Data.Name}" FontWeight="SemiBold" />
                                    <Run Text=" • " Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{x:Bind Data.StudentName}" />
                                </TextBlock>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{x:Bind Data.FinalPrice, Converter={StaticResource DecimalToCurrencyConverter}}" Style="{ThemeResource BodyStrongTextBlockStyle}" FontSize="16" HorizontalAlignment="Right" />
                                    <Border Style="{StaticResource PaidBadgeStyle}" Visibility="{x:Bind Data.IsPaid, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock x:Uid="Paid" Style="{StaticResource PaidTextStyle}" />
                                    </Border>
                                    <Border Style="{StaticResource UnpaidBadgeStyle}" Visibility="{x:Bind Data.IsPaid, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock x:Uid="Unpaid" Style="{StaticResource UnpaidTextStyle}" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>