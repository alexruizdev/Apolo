<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:loc="using:Apolo.Services"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <ScrollView>
        <StackPanel Padding="24"
                    Spacing="16">

            <TextBlock Text="{x:Bind loc:Loc.Menu_Invoicing}"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                <ComboBox Width="280"
                          Header="{x:Bind loc:Loc.Box_Payer}"
                          ItemsSource="{Binding Payers}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="FullName"
                          SelectedValue="{x:Bind ViewModel.SelectedPayerId, Mode=TwoWay}" />
                <Button Content="Load"
                        Click="LoadForPayer_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                        VerticalAlignment="Bottom"/>
                <CheckBox Content="Select all"
                          IsThreeState="True"
                          IsChecked="{x:Bind ViewModel.SelectionState, Mode=TwoWay}"
                          VerticalAlignment="Bottom" />
                <Button Content="Mark selected as paid"
                        Click="MarkPaid_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                        VerticalAlignment="Bottom" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="InvoiceNameBox"
                         Header="Invoice name (optional)"
                         Width="260" />
                <Button Content="Generate PDF..."
                        Click="ExportPdf_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                        VerticalAlignment="Bottom" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="InvoiceNameSearchBox"
                         Header="Search invoice by name"
                         Width="260" />
                <Button Content="Load by invoice name"
                        Click="LoadByName_Click"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                        VerticalAlignment="Bottom" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="24">
                <TextBlock>
                    <Run Text="Total (selected): " />
                    <Run Text="{Binding TotalSelected, Converter={StaticResource DecimalToCurrencyConverter}}" />
                </TextBlock>
                <TextBlock>
                     <Run Text="Total (all): " />
                     <Run Text="{Binding TotalAll, Converter={StaticResource DecimalToCurrencyConverter}}" />
                </TextBlock>
            </StackPanel>

            <StackPanel>
                <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                <InfoBar
                    IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                    Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                    Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
            </StackPanel>

            <ListView ItemsSource="{Binding Attendances}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:InvoiceLine">
                        <StackPanel Spacing="8"
                                    Padding="8"
                                    Orientation="Horizontal">
                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Width="20"
                                      Height="20" />
                            <TextBlock Text="{x:Bind Date, Converter={StaticResource DateFormatConverter}}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind LessonName}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind StudentName}"
                                       VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{x:Bind Price, Converter={StaticResource DecimalToCurrencyConverter}}" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollView>
</Page>
