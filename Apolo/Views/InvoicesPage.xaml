<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Apolo.Views.InvoicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <ScrollView>
        <StackPanel Padding="24"
                    Spacing="16">
            
            <TextBlock Text="Invoicing"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center">
                <ComboBox Width="280"
                          Header="Payer"
                          ItemsSource="{Binding Payers}"
                          SelectedValuePath="Id"
                          DisplayMemberPath="FullName"
                          SelectedValue="{x:Bind ViewModel.SelectedPayerId, Mode=TwoWay}"/>
                <Button Content="Load"
                        Click="LoadForPayer_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                <CheckBox Content="Select all"
                          IsThreeState="True"
                          IsChecked="{x:Bind ViewModel.AllSelected, Mode=TwoWay}" />
                <Button Content="Mark selected as paid"
                        Click="MarkPaid_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                <Button Content="Generate PDF..."
                        Click="ExportPdf_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="24">
                <TextBlock>
                    <Run Text="Total (selected): " />
                    <Run Text="{Binding TotalSelected, Converter={StaticResource DecimalToCurrencyConverter}}" />
                </TextBlock>
                <TextBlock>
                     <Run Text="Total (all): " />
                     <Run Text="{Binding TotalAll, Converter={StaticResource DecimalToCurrencyConverter}}" />
                </TextBlock>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Loading..."
                           Foreground="Gray"
                           Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Tomato"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            </StackPanel>

            <ListView ItemsSource="{Binding Attendances}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:InvoiceAttendanceSummary">
                        <Grid ColumnDefinitions="Auto, 90, *, *, Auto"
                              Padding="6">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind Date}" />
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind LessonName}" />
                            <TextBlock Grid.Column="3"
                                       Text="{x:Bind StudentName}" />
                            <TextBlock Grid.Column="4">
                                <Run Text="{x:Bind Price, Converter={StaticResource DecimalToCurrencyConverter}}" />
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollView>
</Page>
