<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.ViewModels.StudentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <Grid Style="{StaticResource MainGridStyle}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Uid="Students/Title"
                       Style="{ThemeResource TitleLargeTextBlockStyle}" />

            <CommandBar Grid.Column="1"
                        DefaultLabelPosition="Right"
                        Background="Transparent"
                        IsDynamicOverflowEnabled="False">
                <AppBarButton x:Uid="Buttons/New"
                              Icon="Add"
                              Click="NewStudent_Click"
                              IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
            </CommandBar>
        </Grid>

        <!--Status / errors-->
        <StackPanel Grid.Row="1"
                    Spacing="4">
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                     Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                     Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>

        <!--List of student -->
        <ListView Grid.Row="2"
                  ItemsSource="{Binding Students}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="m:StudentSummary">
                    <Grid Style="{StaticResource CardGridStyle}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- INFO -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <TextBlock Text="{x:Bind Name}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="•"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}">
                                <Run x:Uid="Students/Payer"
                                     Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                <Run Text="{x:Bind PayerName}"
                                     FontWeight="SemiBold" />
                            </TextBlock>
                        </StackPanel>

                        <!-- ACTIONS -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <!-- EDIT -->
                            <Button Style="{StaticResource RowActionButtonStyle}"
                                    x:Uid="Students/EditStudent"
                                    Click="EditStudent_Click"
                                    IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Edit" />
                            </Button>
                            <!-- DELETE -->
                            <Button Style="{StaticResource RowDeleteButtonStyle}"
                                    x:Uid="Students/DeleteStudent"
                                    Click="DeleteStudent_Click"
                                    IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Delete" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>

</Page>
