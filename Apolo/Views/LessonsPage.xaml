<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.LessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <Grid Style="{StaticResource MainGridStyle}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Uid="Lessons/Title"
                       Style="{ThemeResource TitleLargeTextBlockStyle}" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button x:Uid="Common/ClearFilters"
                        Command="{x:Bind ViewModel.ClearFiltersCommand}"
                        Visibility="{x:Bind ViewModel.AreFiltersActive, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <ToggleButton x:Name="SidebarToggle"
                              IsChecked="False">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <SymbolIcon Symbol="Filter" />
                        <TextBlock x:Uid="Common/Filters" />
                    </StackPanel>
                </ToggleButton>

                <AppBarButton x:Uid="Buttons/New"
                              Icon="Add"
                              Click="NewLesson_Click"
                              IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
            </StackPanel>
        </Grid>

        <!--Status / errors-->
        <StackPanel Grid.Row="1"
                    Spacing="4">
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                     Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                     Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Lessons List -->
            <ListView Grid.Column="0"
                      ItemsSource="{x:Bind ViewModel.Lessons, Mode=OneWay}"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:LessonSummary">
                        <Grid Style="{StaticResource CardGridStyle}">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{x:Bind Date, Converter={StaticResource DateFormatConverter}}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4"
                                            Margin="0,8,0,0">
                                    <SymbolIcon Symbol="Clock"
                                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind DurationMinutes}"
                                               Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Uid="Common/MinuteAbbrev"
                                               Style="{ThemeResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock Style="{ThemeResource BodyTextBlockStyle}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="{x:Bind Name}"
                                         FontWeight="SemiBold" />
                                    <Run Text=" • "
                                         Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{x:Bind StudentName}" />
                                </TextBlock>

                                <Border Style="{StaticResource PaidBadgeStyle}"
                                        Visibility="{x:Bind IsPaid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock x:Uid="Paid"
                                               Style="{StaticResource PaidTextStyle}" />
                                </Border>
                                <Border Style="{StaticResource UnpaidBadgeStyle}"
                                        Visibility="{x:Bind IsPaid, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <TextBlock x:Uid="Unpaid"
                                               Style="{StaticResource UnpaidTextStyle}" />
                                </Border>

                                <TextBlock Text="{x:Bind ShortNote}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           FontStyle="Italic"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis">
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind Notes}"
                                                 MaxWidth="400" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="{x:Bind FinalPrice, Converter={StaticResource DecimalToCurrencyConverter}}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                                           HorizontalAlignment="Right"
                                           FontSize="16" />
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4"
                                            Margin="0,4,0,0"
                                            HorizontalAlignment="Right">
                                    <FontIcon Glyph="&#xE948;"
                                              FontSize="12"
                                              Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind Tip, Converter={StaticResource DecimalToCurrencyConverter}}"
                                               Style="{ThemeResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind BillingName}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis">
                                    <ToolTipService.ToolTip>
                                        <ToolTip x:Uid="Common/BillingDocument" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource RowActionButtonStyle}"
                                        Click="EditLesson_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                        x:Uid="Edit_Lesson">
                                    <SymbolIcon Symbol="Edit" />
                                    <ToolTipService.ToolTip>{x:Bind loc:Loc.Common_EditLesson}</ToolTipService.ToolTip>
                                </Button>
                                <Button Style="{StaticResource RowActionButtonStyle}"
                                        Click="ChangePayment_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                        x:Uid="Change_Payment">
                                    <SymbolIcon Symbol="Shop" />
                                    <ToolTipService.ToolTip>{x:Bind loc:Loc.Common_ChangePaymentStatus}</ToolTipService.ToolTip>
                                </Button>
                                <Button Style="{StaticResource RowDeleteButtonStyle}"
                                        Click="DeleteLesson_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                        x:Uid="Delete_Lesson">
                                    <SymbolIcon Symbol="Delete" />
                                    <ToolTipService.ToolTip>{x:Bind loc:Loc.Action_DeleteLesson}</ToolTipService.ToolTip>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Filter -->
            <ScrollViewer Grid.Column="1"
                          Visibility="{x:Bind SidebarToggle.IsChecked, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Width="320"
                          Margin="16,0,0,0"
                          Padding="16">
                <StackPanel Style="{StaticResource CardPanelStyle}">
                    <TextBlock x:Uid="Common/FilterResults"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />

                    <AutoSuggestBox x:Uid="Search_Student"
                                    Text="{x:Bind ViewModel.FilterStudentName, Mode=TwoWay}"
                                    QueryIcon="Find" />
                    <AutoSuggestBox x:Uid="Search_Payer"
                                    Text="{x:Bind ViewModel.FilterPayerName, Mode=TwoWay}"
                                    QueryIcon="Find" />

                    <ComboBox x:Uid="Common/PaymentStatus"
                              HorizontalAlignment="Stretch"
                              SelectedIndex="{x:Bind ViewModel.SelectedPaymentStatusIndex, Mode=TwoWay}">
                        <ComboBoxItem x:Uid="Common/AllStatuses" />
                        <ComboBoxItem x:Uid="Common/OnlyPaid" />
                        <ComboBoxItem x:Uid="Common/OnlyUnpaid" />
                    </ComboBox>

                    <CalendarDatePicker x:Uid="Common/StartDate"
                                        HorizontalAlignment="Stretch"
                                        Date="{x:Bind ViewModel.FilterStartDate, Mode=TwoWay}"
                                        DateFormat="{}{day.integer}/{month.integer}/{year.full}" />
                    <CalendarDatePicker x:Uid="Common/EndDate"
                                        HorizontalAlignment="Stretch"
                                        Date="{x:Bind ViewModel.FilterEndDate, Mode=TwoWay}"
                                        DateFormat="{}{day.integer}/{month.integer}/{year.full}" />

                    <Button x:Uid="Buttons/ApplyFilters"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.LoadCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>

</Page>
