<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.LessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <ScrollView>
        <StackPanel Padding="24"
                    Spacing="16">

            <StackPanel Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">
                <TextBlock Text="Lessons"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <ToggleSwitch Header="Only updaid"
                              IsOn="{x:Bind ViewModel.ShownOnlyUnpaid, Mode=TwoWay}" />
                <Button Content="New lesson"
                        Click="NewLesson_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />

            </StackPanel>

            <StackPanel>
                <TextBlock Text="Loading..."
                           Foreground="Gray"
                           Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Tomato"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            </StackPanel>

            <ListView ItemsSource="{Binding Lessons}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:LessonSummary">
                        <StackPanel Spacing="8"
                                    Padding="8">
                            <!--Header line-->
                            <Grid ColumnDefinitions="*, Auto, Auto"
                                  RowDefinitions="Auto, Auto">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Date}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="-" />
                                    <TextBlock Text="{x:Bind Name}"
                                               FontWeight="SemiBold" />
                                    <TextBlock>
                                        <Run Text="Duration: " />
                                        <Run Text="{x:Bind DurationMinutes}" />
                                        <Run Text=" min" />
                                    </TextBlock>
                                    <TextBlock Text="-" />
                                    <TextBlock>
                                        <Run Text="Total: " />
                                        <Run Text="{x:Bind GrandTotal, Converter={StaticResource DecimalToCurrencyConverter}}" />
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Button Content="Edit lesson"
                                            Click="EditLesson_Click"
                                            IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                    <Button Content="Add attendance"
                                            Click="AddAttendances_Click"
                                            IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                </StackPanel>
                            </Grid>

                            <!--Attendances-->
                            <ListView ItemsSource="{x:Bind Attendances}"
                                      SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="m:AttendanceSummary">
                                        <Grid ColumnDefinitions="Auto, Auto, Auto, Auto"
                                              Padding="4">
                                            <TextBlock Text="{x:Bind StudentName}" />
                                            <CheckBox Grid.Column="2"
                                                      Content="Paid"
                                                      IsChecked="{x:Bind IsPaid}"
                                                      IsHitTestVisible="False" />
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                <Button Content="Edit"
                                                        Click="EditAttendances_Click"
                                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                                <Button Content="Remove"
                                                        Click="RemoveAttendance_Click"
                                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            
                            <AppBarSeparator />
                            
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollView>

</Page>
