<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.LessonsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:loc="using:Apolo.Services"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <StackPanel Padding="24"
                Spacing="16">

        <TextBlock Text="{x:Bind loc:Loc.Menu_Lessons}"
                    FontSize="28"
                    FontWeight="SemiBold" />
        <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Top">
            <ToggleSwitch Header="Only updaid"
                            IsOn="{x:Bind ViewModel.ShownOnlyUnpaid, Mode=TwoWay}" />
            <DatePicker DayVisible="False" Date="{x:Bind ViewModel.DateFiler, Mode=TwoWay}"/>
            <CommandBar DefaultLabelPosition="Right">
                <AppBarButton Label="Refresh lessons" Icon="Refresh"
                              Command="{x:Bind ViewModel.LoadCommand}"
                              IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                <AppBarButton Label="New lesson" Icon="Add"
                              Click="NewLesson_Click"
                              IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
            </CommandBar>

        </StackPanel>

        <StackPanel>
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar
                IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>
        
        <ScrollView MaxHeight="500">
            
            <ListView ItemsSource="{x:Bind ViewModel.Lessons, Mode=OneWay}"
                        SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:LessonSummary">
                        <Grid Padding="12" 
                              Margin="0,4,0,8" 
                              ColumnSpacing="16"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              CornerRadius="6"
                              BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                              BorderThickness="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{x:Bind Date, Converter={StaticResource DateFormatConverter}}"
                                           FontWeight="SemiBold" 
                                           FontSize="15" />

                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                    <SymbolIcon Symbol="Clock" Foreground="Gray" />
                                    <TextBlock Text="{x:Bind DurationMinutes}" Foreground="Gray" />
                                    <TextBlock Text="min" Foreground="Gray" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="16" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                                    <Run Text="{x:Bind Name}" FontWeight="SemiBold" />
                                    <Run Text=" • " Foreground="Gray" />
                                    <Run Text="{x:Bind StudentName}" />
                                </TextBlock>
                                <Border Background="#E6F4EA" 
                                        Padding="6,2" 
                                        CornerRadius="4" 
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Left"
                                        Visibility="{x:Bind IsPaid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="PAID" 
                                               Foreground="#137333" 
                                               FontSize="10" 
                                               FontWeight="Bold" />
                                </Border>

                                <Border Background="#FCE8E6" 
                                        Padding="6,2" 
                                        CornerRadius="4" 
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Left"
                                        Visibility="{x:Bind IsPaid, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <TextBlock Text="UNPAID" 
                                                Foreground="#C5221F" 
                                                FontSize="10" 
                                                FontWeight="Bold" />
                                </Border>

                                <TextBlock Text="{x:Bind ShortNote}" 
                                           Foreground="DimGray" 
                                           FontStyle="Italic" 
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis">
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="{x:Bind Notes}" MaxWidth="400" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>
                            </StackPanel>


                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="{x:Bind FinalPrice, Converter={StaticResource DecimalToCurrencyConverter}}"
                                           FontWeight="Bold" 
                                           FontSize="16" 
                                           HorizontalAlignment="Right" />
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0" HorizontalAlignment="Right">
                                    <FontIcon Glyph="&#xE948;" Foreground="Gray" />
                                    <TextBlock Text="{x:Bind Tip, Converter={StaticResource DecimalToCurrencyConverter}}" Foreground="Gray" />
                                </StackPanel>
                                
                                <TextBlock Text="{x:Bind BillingName}" 
                                           Foreground="Gray" 
                                           FontSize="12" 
                                           HorizontalAlignment="Right"
                                           Margin="0,2,0,0"
                                           TextTrimming="CharacterEllipsis">
                                    <ToolTipService.ToolTip>
                                        <ToolTip Content="Billing Document" />
                                    </ToolTipService.ToolTip>
                                </TextBlock>

                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Click="EditLesson_Click" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                    <SymbolIcon Symbol="Edit" />
                                    <ToolTipService.ToolTip>Edit lesson</ToolTipService.ToolTip>
                                </Button>

                                <Button Click="ChangePayment_Click" 
                                        Background="Transparent" 
                                        BorderThickness="0"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                    <SymbolIcon Symbol="Shop" />
                                    <ToolTipService.ToolTip>Change payment status</ToolTipService.ToolTip>
                                </Button>

                                <Button Click="DeleteLesson_Click" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Foreground="Red"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                    <SymbolIcon Symbol="Delete" />
                                    <ToolTipService.ToolTip>Delete lesson</ToolTipService.ToolTip>
                                </Button>
                            </StackPanel>

                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollView>
    </StackPanel>

</Page>
