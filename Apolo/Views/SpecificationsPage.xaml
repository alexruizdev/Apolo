<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.SpecificationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:loc="using:Apolo.Services"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <StackPanel Padding="24"
                Spacing="16">

        <TextBlock Text="{x:Bind loc:Loc.Menu_Specifications}"
                    FontSize="28"
                    FontWeight="SemiBold" />

        <Button Content="New specification"
            Click="NewSpecification_Click"
            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />

        <StackPanel>
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar
                IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>

        <ScrollView MaxHeight="500">
            <ListView ItemsSource="{Binding Specifications}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:SpecificationSummary">
                        <Grid ColumnDefinitions="*, Auto"
                                Padding="8">
                            <StackPanel Orientation="Vertical"
                                        Spacing="2">
                                <TextBlock>
                                    <Run Text="{x:Bind StudentName}" FontWeight="SemiBold" />
                                    <Run Text=" - " />
                                    <Run Text="{x:Bind SpecificationName}" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Service: " />
                                    <Run Text="{x:Bind ServiceName}" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Duration: " />
                                    <Run Text="{x:Bind DurationMinutes}" />
                                    <Run Text=" min" />
                                </TextBlock>
                                <TextBlock>
                                    <Run Text="Price: " />
                                    <Run Text="{x:Bind Price}" />
                                </TextBlock>
                                <CheckBox IsChecked="{x:Bind IsOnline}"
                                            IsHitTestVisible="False"
                                            Content="Online" />
                                <CheckBox IsChecked="{x:Bind IsWeekenOrHoliday}"
                                        IsHitTestVisible="False"
                                        Content="Weekend or holiday" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Create lesson"
                                        Click="CreateLesson_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                <Button x:Uid="Buttons/Edit"
                                        Click="EditSpecification_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                <Button Content="{x:Bind loc:Loc.Buttons_Delete}"
                                        Click="DeleteSpecification_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollView>
    </StackPanel>
</Page>
