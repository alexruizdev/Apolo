<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.SpecificationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <Grid Style="{StaticResource MainGridStyle}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 1. Header & Actions Zone -->
            <RowDefinition Height="Auto" /> <!-- 2. System Messages Zone -->
            <RowDefinition Height="*" />    <!-- 3. Main Data List View -->
        </Grid.RowDefinitions>

        <!-- ========================================== -->
        <!-- 1. HEADER & ACTIONS ZONE                   -->
        <!-- ========================================== -->
        <Grid Grid.Row="0" VerticalAlignment="Center">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Uid="Specifications/Title" Style="{ThemeResource TitleLargeTextBlockStyle}" />

            <CommandBar Grid.Column="1" DefaultLabelPosition="Right" Background="Transparent" IsDynamicOverflowEnabled="False">
                <AppBarButton x:Uid="Buttons/New" Icon="Add"
                  Click="NewSpecification_Click"
                  IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
            </CommandBar>
        </Grid>

        <!-- ========================================== -->
        <!-- 2. SYSTEM MESSAGES ZONE                    -->
        <!-- ========================================== -->
        <StackPanel Grid.Row="1" Spacing="4">
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                     Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                     Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>

        <!-- ========================================== -->
        <!-- 3. MAIN DATA LIST VIEW                     -->
        <!-- ========================================== -->
        <ListView ItemsSource="{Binding Specifications}" Grid.Row="2" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="m:SpecificationSummary">
                    <Grid Style="{StaticResource CardGridStyle}">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- INFO -->
                        <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                            <!-- Student & Specification Identification Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind StudentName}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="•" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyTextBlockStyle}" />
                            </StackPanel>

                            <!-- Service, Duration, and Price Sub-Details -->
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                    <Run x:Uid="Specifications/Service" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{x:Bind ServiceName}" FontWeight="SemiBold" />
                                </TextBlock>

                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                    <Run x:Uid="Specifications/Duration" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{x:Bind DurationMinutes}" FontWeight="SemiBold" />
                                    <Run x:Uid="Common/MinuteAbbrev" />
                                </TextBlock>

                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}">
                                    <Run x:Uid="Common/Price" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                    <Run Text="{x:Bind Price, Converter={StaticResource DecimalToCurrencyConverter}}" FontWeight="SemiBold" />
                                </TextBlock>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                <!-- Online Status Badge -->
                                <Border Style="{StaticResource OnlineBadgeStyle}" 
                                        Visibility="{x:Bind IsOnline, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock x:Uid="Common/Online" Style="{StaticResource OnlineTextStyle}" />
                                </Border>

                                <!-- Weekend or Holiday Premium Status Badge -->
                                <Border Style="{StaticResource WeekendBadgeStyle}"
                                        Visibility="{x:Bind IsWeekendOrHoliday, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock x:Uid="Common/WeekendOrHoliday" Style="{StaticResource WeekendTextStyle}" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Side: Row Action Controls featuring clean icons -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <Button x:Uid="Common/EditSpecification" Style="{StaticResource RowActionButtonStyle}" Click="EditSpecification_Click" IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Edit" />
                            </Button>
                            <Button x:Uid="Common/CreateLesson" Style="{StaticResource RowActionButtonStyle}" Click="CreateLesson_Click" IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Calendar" />
                            </Button>
                            <Button x:Uid="Common/DeleteSpecification" Style="{StaticResource RowDeleteButtonStyle}" Click="DeleteSpecification_Click" IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Delete" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
