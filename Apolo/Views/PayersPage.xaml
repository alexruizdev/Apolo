<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Pages.PayersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <ScrollViewer>
        <StackPanel Padding="24"
                    Spacing="16">

            <TextBlock Text="Payers"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <!--Status / errors-->
            <StackPanel>
                <TextBlock Text="Loading..."
                           Foreground="Gray"
                           Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="Tomato"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
            </StackPanel>

            <!--List of payers-->
            <ListView ItemsSource="{Binding Payers}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:PayerSummary">
                        <Grid ColumnDefinitions="*, Auto"
                              Padding="8">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="12"
                                        Padding="8">
                                <TextBlock Text="{x:Bind FullName}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="-" />
                                <TextBlock>
                                <Run Text="Outstanding:" />
                                <Run Text="{x:Bind Outstanding, Converter={StaticResource DecimalToCurrencyConverter}}" />
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Content="Edit"
                                        Click="EditPayer_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                <Button Content="Delete"
                                        Click="DeletePayer_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <AppBarSeparator />

            <!--Form to add a new payer-->
            <StackPanel Spacing="8">
                <TextBlock Text="Add new payer"
                           FontWeight="SemiBold" />
                <TextBox Header="First Name"
                         Text="{Binding NewFirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Last Name"
                         Text="{Binding NewLastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Button Content="Add"
                        Command="{Binding AddPayerCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
