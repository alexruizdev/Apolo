<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:loc="using:Apolo.Services"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <Grid Style="{StaticResource MainGridStyle}">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <Grid Grid.Row="0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="{x:Bind loc:Loc.Menu_Services}"
                       Style="{ThemeResource TitleLargeTextBlockStyle}" />

            <CommandBar Grid.Column="1" DefaultLabelPosition="Right" Background="Transparent" IsDynamicOverflowEnabled="False">
                <AppBarButton Label="New" Icon="Add"
                  Click="NewService_Click"
                  IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
            </CommandBar>
            
        </Grid>

        <!--Status / errors-->
        <StackPanel Grid.Row="1" Spacing="4">
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                     Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                     Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>

        <ListView Grid.Row="2" 
                  ItemsSource="{Binding Services}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="m:ServiceSummary">
                    <Grid Style="{StaticResource CardGridStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- INFO -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />

                            <TextBlock Text="•" 
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                            <TextBlock Style="{ThemeResource BodyTextBlockStyle}">
                                <Run Text="Price:" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                <Run Text="{x:Bind Price, Converter={StaticResource DecimalToCurrencyConverter}}" FontWeight="SemiBold" />
                            </TextBlock>

                            <Border Style="{StaticResource OnlineBadgeStyle}" VerticalAlignment="Center"
                                    Visibility="{x:Bind IsPricePerHour, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="PER HOUR" 
                                           Style="{StaticResource OnlineTextStyle}"/>
                            </Border>
                        </StackPanel>

                        <!-- ACTIONS -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">

                            <Button Style="{StaticResource RowActionButtonStyle}"
                                    Click="EditService_Click"
                                    IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Edit" />
                                <ToolTipService.ToolTip>Edit service</ToolTipService.ToolTip>
                            </Button>

                            <Button Style="{StaticResource RowDeleteButtonStyle}"
                                    Click="DeleteService_Click"
                                    IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                <SymbolIcon Symbol="Delete" />
                                <ToolTipService.ToolTip>Delete service</ToolTipService.ToolTip>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>