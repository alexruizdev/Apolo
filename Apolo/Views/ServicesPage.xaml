<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:loc="using:Apolo.Service"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <StackPanel Padding="24"
                Spacing="16">

        <TextBlock Text="{x:Bind loc:Loc.Menu_Services}"
                    FontSize="28"
                    FontWeight="SemiBold" />

        <Button Content="New service"
                Click="NewService_Click"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
        <StackPanel>
            <TextBlock Text="Loading..."
                        Foreground="Gray"
                        Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock Text="{Binding ErrorMessage}"
                        Foreground="Tomato"
                        TextWrapping="Wrap"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />
        </StackPanel>

        <ScrollView MaxHeight="500">
            <ListView ItemsSource="{Binding Services}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:ServiceSummary">
                        <Grid ColumnDefinitions="*, Auto"
                                Padding="8">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind Name}"
                                            FontWeight="SemiBold" />
                                <TextBlock Text="-" />
                                <TextBlock>
                                    <Run Text="Price:" />
                                    <Run Text="{x:Bind PricePerHour, Converter={StaticResource DecimalToCurrencyConverter}}" />
                                </TextBlock>

                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button x:Uid="Buttons/Edit"
                                        Click="EditService_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                <Button Content="{x:Bind loc:Loc.Buttons_Delete}"
                                        Click="DeleteService_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollView>
    </StackPanel>
</Page>
