<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:loc="using:Apolo.Services"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <StackPanel Padding="24"
                Spacing="16">

        <TextBlock Text="{x:Bind loc:Loc.Menu_Services}"
                    FontSize="28"
                    FontWeight="SemiBold" />

        <Button Content="New service"
                Click="NewService_Click"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
        <StackPanel>
            <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <InfoBar
                IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
        </StackPanel>

        <ScrollView MaxHeight="500">
            <ListView ItemsSource="{Binding Services}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="m:ServiceSummary">
                        <Grid ColumnDefinitions="*, Auto"
                                Padding="8">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind Name}"
                                            FontWeight="SemiBold" 
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="-" 
                                        VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="Price:" />
                                    <Run Text="{x:Bind Price, Converter={StaticResource DecimalToCurrencyConverter}}" />
                                </TextBlock>
                                <CheckBox IsChecked="{x:Bind IsPricePerHour}"
                                          Content="Price/hour"
                                          IsEnabled="False" />

                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button x:Uid="Buttons/Edit"
                                        Click="EditService_Click"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                                <Button Content="{x:Bind loc:Loc.Buttons_Delete}"
                                        Click="DeleteService_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        IsEnabled="{Binding ElementName=PageRoot, Path=ViewModel.IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollView>
    </StackPanel>
</Page>
