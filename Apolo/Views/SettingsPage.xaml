<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:loc="using:Apolo.Service"
      xmlns:m="using:Models"
      x:Name="PageRoot"
      Loaded="Page_Loaded">

    <ScrollView>
        <StackPanel Padding="24"
                    Spacing="16">

            <TextBlock Text="{x:Bind loc:Loc.Menu_Settings}"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="Gray"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <Grid ColumnSpacing="24"
                  RowSpacing="12"
                  ColumnDefinitions="*,*">

                <!--left column-->
                <StackPanel Grid.Column="0"
                            Spacing="8">
                    <TextBox Header="Full name"
                             Text="{x:Bind ViewModel.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Address"
                             Text="{x:Bind ViewModel.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="ZIP"
                             Text="{x:Bind ViewModel.ZipCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="City"
                             Text="{x:Bind ViewModel.City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Phone"
                             Text="{x:Bind ViewModel.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- right column-->
                <StackPanel Grid.Column="1"
                            Spacing="8">
                    <TextBox Header="Email"
                             Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Bank name"
                             Text="{x:Bind ViewModel.BankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="Bank account"
                             Text="{x:Bind ViewModel.BankAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Header="CIF"
                             Text="{x:Bind ViewModel.TaxId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                </StackPanel>

            </Grid>

            <StackPanel Orientation="Horizontal"
                        Spacing="12">
                <Button Content="Load"
                        Command="{Binding LoadCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" />
            </StackPanel>

        </StackPanel>

    </ScrollView>

</Page>
