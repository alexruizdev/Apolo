<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Apolo.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Apolo.Views"
      xmlns:vm="using:Apolo.ViewModels"
      xmlns:m="using:Models"
      x:Name="PageRoot">

    <ScrollView VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" MaxWidth="1000" HorizontalAlignment="Stretch">
            
            <!-- ========================================== -->
            <!-- HEADER & STATE ZONE                        -->
            <!-- ========================================== -->
            <TextBlock x:Uid="Settings/Title" Style="{ThemeResource TitleLargeTextBlockStyle}" />

            <HyperlinkButton x:Uid="Settings/UserManual"
                             NavigateUri="https://github.com/alexruizdev/Apolo/wiki/Manual" />

            <StackPanel Spacing="4">
                <ProgressBar IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                <InfoBar IsOpen="{x:Bind ViewModel.OpenInfoBar, Mode=TwoWay}"
                         Severity="{x:Bind ViewModel.InfoBarType, Converter={StaticResource InfoBarTypeConverter}, Mode=TwoWay}"
                         Message="{x:Bind ViewModel.InfoMessage, Mode=TwoWay}" />
            </StackPanel>

            <!-- ========================================== -->
            <!-- SECTION 1: MAIN INFORMATION                -->
            <!-- ========================================== -->
            <Expander x:Uid="Settings/MainInformation" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Padding="0,8,0,4">
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <TextBox Grid.Column="0" x:Uid="Common/Name" Text="{x:Bind ViewModel.Profile.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1" x:Uid="Common/Phone" Text="{x:Bind ViewModel.Profile.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                    </Grid>

                    <TextBox x:Uid="Common/Address" Text="{x:Bind ViewModel.Profile.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    
                    <Grid ColumnDefinitions="*, *">
                        <TextBox Grid.Column="0" x:Uid="Common/ZipCode" Text="{x:Bind ViewModel.Profile.ZipCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1" x:Uid="Common/City" Text="{x:Bind ViewModel.Profile.City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                    </Grid>

                    <TextBox  x:Uid="Common/Email" Text="{x:Bind ViewModel.Profile.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  />
                </StackPanel>
            </Expander>

            <!-- ========================================== -->
            <!-- SECTION 2: BILLING & TAX DETAILS           -->
            <!-- ========================================== -->
            <Expander x:Uid="Settings/BillingTaxDetails" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Padding="0,8,0,4">
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <TextBox Grid.Column="0" x:Uid="Common/TaxId" Text="{x:Bind ViewModel.Profile.TaxId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1" x:Uid="Common/BankName" Text="{x:Bind ViewModel.Profile.BankName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, *">
                        <TextBox Grid.Column="0" x:Uid="Common/BankAccount" Text="{x:Bind ViewModel.Profile.BankAccount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <NumberBox Grid.Column="1" x:Uid="Common/TaxPercent"
                               Value="{x:Bind ViewModel.Profile.IvaPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                               SmallChange="1" LargeChange="5" SpinButtonPlacementMode="Inline" Margin="4,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Expander>

            <!-- ========================================== -->
            <!-- SECTION 3: CONFIGURATION & FEES            -->
            <!-- ========================================== -->
            <Expander x:Uid="Settings/ConfigurationFees" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Margin="0,10,0,0">
                    <!-- Travel Allowance & Weekend Fee -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <NumberBox x:Uid="Common/TravelAllowance"
                               Value="{x:Bind ViewModel.Profile.TravelAllowance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                               PlaceholderText="0.00" SpinButtonPlacementMode="Inline" Margin="0,0,4,0"/>
                        <NumberBox Grid.Column="1" x:Uid="Common/WeekendFee"
                               Value="{x:Bind ViewModel.Profile.WeekendFee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                               PlaceholderText="0.00" SpinButtonPlacementMode="Inline" Margin="4,0,0,0"/>
                    </Grid>
                
                    <!-- Billing Folder -->
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Uid="Settings/BillingFolder" Style="{ThemeResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                        <TextBox x:Name="BillingFolderTextBlock" Grid.Row="1" Text="{x:Bind ViewModel.Profile.BillingFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" x:Uid="Settings/SelectFolder"/>
                        <Button Grid.Row="1" Grid.Column="1" x:Uid="Settings/PickFolder" Click="PickBillingFolder_Click" Margin="8,0,0,0"/>

                    </Grid>
                    
                    <!-- Backup Folder -->
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Uid="Settings/BackupsFolder" Style="{ThemeResource BodyTextBlockStyle}" Margin="0,0,0,4"/>
                        <TextBox x:Name="BackupFolderTextBlock" Grid.Row="1" Text="{x:Bind ViewModel.Profile.BackupFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" x:Uid="Settings/SelectFolder"/>
                        <Button Grid.Row="1" Grid.Column="1" x:Uid="Settings/PickFolder" Click="PickBackupFolder_Click" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Language Option -->
                    <StackPanel>
                        <TextBlock Text="Language / Idioma"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   FontWeight="SemiBold" />

                        <ComboBox x:Name="LanguageComboBox"
                                  Width="300"
                                  ItemsSource="{x:Bind ViewModel.Languages}"
                                  SelectedItem="{x:Bind ViewModel.SelectedLenguage, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" />

                        <TextBlock Text="Changing this will instantly translate supported UI controls and layouts."
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- PRIMARY SAVING ACTION TOOLBAR -->
            <CommandBar DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent" Margin="0,4,0,0">
                <AppBarButton Icon="Save" x:Uid="Buttons/Save" Command="{Binding SaveCommand}"/>
                <AppBarSeparator />
                <AppBarButton Icon="Refresh" x:Uid="Buttons/DiscardChanges"  Command="{Binding RefreshProfileCommand}"/>
                <AppBarSeparator />
                <AppBarButton Icon="Delete" x:Uid="Buttons/DeleteProfile" Foreground="{ThemeResource SystemFillColorCriticalBrush}"  Command="{Binding DeleteCommand}"/>
            </CommandBar>

            <!-- ========================================== -->
            <!-- DATA MANAGEMENT UTILITIES                  -->
            <!-- ========================================== -->
            <StackPanel Spacing="12" Margin="0,16,0,0">
                <TextBlock x:Uid="Settings/DataManagement" Style="{StaticResource SubtitleTextBlockStyle}"/>

                <Border Style="{StaticResource SettingUtilitiesStyle}">

                    <StackPanel Spacing="8">

                        <!-- Safe/Standard File Actions -->
                        <CommandBar DefaultLabelPosition="Right"  HorizontalAlignment="Left"  Background="Transparent">
                            <AppBarButton x:Uid="Buttons/ImportBackup" Icon="Import" Click="ImportExcelButton_Click"/>
                            <AppBarButton Icon="Save" x:Uid="Buttons/ExportExcel" Click="ExportExcelButton_Click"/>
                            <AppBarSeparator />
                            <AppBarButton x:Uid="Buttons/ImportArchive" Icon="ImportAll" Click="ImportArchiveButton_Click"/>
                            <AppBarButton x:Uid="Buttons/SaveArchive" Icon="SaveLocal" Click="ExportArchiveButton_Click"/>
                            <AppBarButton Icon="Library" x:Uid="Buttons/Archive" Click="ArchiveButton_Click"/>
                            <AppBarButton Icon="Import" x:Uid="Buttons/Retrieve" Click="RetrieveFromArchiveButton_Click"/>
                        </CommandBar>

                        <MenuFlyoutSeparator />

                        <!-- Danger/Destructive Actions Strip -->
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Settings/DangerZone" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            <CommandBar DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent">
                                <AppBarButton x:Uid="Settings/DeleteDatabase" Icon="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Click="DeleteDatabaseButton_Click"/>
                                <AppBarButton x:Uid="Settings/DeleteArchive" Icon="Delete" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Click="DeleteArchiveButton_Click"/>
                            </CommandBar>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollView>
</Page>
